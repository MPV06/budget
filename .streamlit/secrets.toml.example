# Streamlit secrets — copy to `secrets.toml` (gitignored) for local Streamlit Cloud-style dev,
# OR paste these contents into the App Settings → Secrets panel on Streamlit Community Cloud.
#
# Generate the password hash with:  python -m scripts.set_password

# Auth
APP_PASSWORD_HASH = "$2b$12$paste_your_bcrypt_hash_here..."

# Plaid (optional — also accepts env vars / .env)
PLAID_CLIENT_ID = "your_client_id"
PLAID_SECRET = "your_sandbox_or_production_secret"
PLAID_ENV = "sandbox"                # sandbox | development | production
PLAID_ACCESS_TOKEN = ""              # filled in after Plaid Link onboarding

# App
PAYCHECK_NET_AMOUNT = 2890.00

# ── Storage ────────────────────────────────────────────────────────
# PERSISTENT (Streamlit Cloud + Supabase free tier — recommended):
#   uncomment and paste the connection string from your Supabase project
#   → Settings → Database → Connection string → URI (use the 'Session pooler'
#   one, format starts with 'postgresql://...').
# DATABASE_URL = "postgresql://postgres.xxxxxxxx:YOUR_PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres"
DATABASE_URL = ""
# EPHEMERAL fallback (local dev OR if DATABASE_URL is empty):
DB_PATH = "/tmp/budget.db"   # /tmp on Cloud; "./data/budget.db" locally
