# Plaid credentials — get from https://dashboard.plaid.com
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox            # sandbox | development | production
PLAID_ACCESS_TOKEN=          # filled in after first Plaid Link onboarding

# App settings
PAYCHECK_NET_AMOUNT=         # e.g. 2500.00

# Storage — leave DATABASE_URL empty to use SQLite at DB_PATH.
# Set DATABASE_URL to a Postgres connection string (e.g. Supabase) for
# persistent data on Streamlit Cloud.
DATABASE_URL=
DB_PATH=./data/budget.db

# Auth (generate with: python -m scripts.set_password)
APP_PASSWORD_HASH=
